SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,https://app.capellaops.com
PUBLIC_FRONTEND_URL=http://localhost:5173
# En producción:
# PUBLIC_FRONTEND_URL=https://app.capellaops.com
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_ENABLED=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_VERIFY_CHANNEL=sms
VERIFY_DEV_MODE=false
VERIFY_DEV_CODE=123456

# Opcion 1: URL completa (tiene prioridad sobre AZURE_SQL_*)
# DATABASE_URL=mssql+pyodbc://usuario:password@servidor.database.windows.net:1433/CapellaOpsDB?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no&Connection+Timeout=30

# Opcion 2: partes de Azure SQL
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=CapellaOpsDB
AZURE_SQL_USERNAME=adminuser
AZURE_SQL_PASSWORD=your-password
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server

# Storage de imagenes de materiales
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=capellaops-media
AZURE_STORAGE_PUBLIC_BASE_URL=
